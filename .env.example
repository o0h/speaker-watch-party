# 対象のSpeakerDeck URL（デッキは1つ固定）
SPEAKERDECK_URL=https://speakerdeck.com/o0h/my-talk

# Bearer tokenによるAPI認証（AppleScriptとの共有シークレット）
API_TOKEN=your-secret-token-here

# Mercure Hub 署名シークレット
MERCURE_JWT_SECRET=change-this-secret

# Caddyが使うドメイン名（HTTPS証明書の自動取得に使用）
# ローカル開発時は localhost を指定（HTTP）
DOMAIN=example.com

# スライド番号オフセット（Keynoteのビルドステップがある場合に調整）
# effective = Keynoteのスライド番号 + SLIDE_OFFSET
SLIDE_OFFSET=0

# Xポストボタンに付けるハッシュタグ（カンマ区切り、#不要）
TWEET_HASHTAGS=phperkaigi,a
